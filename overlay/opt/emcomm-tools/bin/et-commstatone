#!/usr/bin/env bash
#
# Author: Clifton Jones
# Description:
#  EmComm Tools wrapper for CommStatOne - JS8Call group add-on
#  https://github.com/W5DMH/commstatone
#

[ -z "$ET_HOME" ] && ET_HOME="/opt/emcomm-tools"

# JS8Call listening TCP port
JS8CALL_TCP_PORT=2442

COMMSTATONE_DIR="${HOME}/apps/commstatone"
COMMSTATONE_CONF="${COMMSTATONE_DIR}/config.ini"
COMMSTATONE_CONF_TEMPLATE="${ET_HOME}/conf/template.d/commstatone.ini"

usage() {
  echo "usage: $(basename $0) <command>"
  echo "  <command>"
  echo "    start           - Start CommStatOne"
  echo "    update-config   - Update configuration for selected mode"
}

if [ $# -ne 1 ]; then
  usage
  exit 1
fi

notify_user() {
  notify-send \
   -t 5000 \
   --app-name="EmComm Tools" \
   "$1"
}

wait_for_js8call() {
  # Maximum time to wait (in seconds) for JS8Call listener
  local timeout=30
  local sleep_interval=1  # Check every 1 second
  # Counter for listener timeout
  local elapsed=0

  # Loop until port is open or timeout is reached
  while ! nc -z "localhost" "${JS8CALL_TCP_PORT}" 2>/dev/null; do
      if [ ${elapsed} -ge ${timeout} ]; then
          notify-send -u critical -i \
        /usr/share/icons/Yaru/48x48/status/dialog-information.png \
        "Timed-out waiting for JS8Call to be listening"
          return 1
      fi
      sleep $sleep_interval
      elapsed=$((elapsed + sleep_interval))
      echo "Waiting... (${elapsed}s elapsed)"
  done

  return 0
}

update-config() {
  [ -z "$ET_USER_CONFIG" ] && ET_USER_CONFIG="${HOME}/.config/emcomm-tools/user.json"

  CALLSIGN=$(cat ${ET_USER_CONFIG} | jq -r .callsign)
  GRID=$(cat ${ET_USER_CONFIG} | jq -r .grid)

  if [ "${CALLSIGN}" = "N0CALL" ]; then
    notify_user "Can't start CommStatOne. No callsign set. Run: et-user."
    exit 1
  fi

  if [[ ! -d ${COMMSTATONE_DIR} ]]; then
    notify_user "CommStatOne not found at ${COMMSTATONE_DIR}. Run the et-os-addons install."
    exit 1
  fi

  if [[ ! -e ${COMMSTATONE_CONF_TEMPLATE} ]]; then
    notify_user "CommStatOne template not found at ${COMMSTATONE_CONF_TEMPLATE}."
    exit 1
  fi

  et-log "Updating CommStatOne config file: ${COMMSTATONE_CONF} ..."
  cp -v ${COMMSTATONE_CONF_TEMPLATE} ${COMMSTATONE_CONF}
  sed -i "s|{{ET_CALLSIGN}}|${CALLSIGN}|g" ${COMMSTATONE_CONF}
  sed -i "s|{{ET_GRID}}|${GRID}|g" ${COMMSTATONE_CONF}
  sed -i "s|{{ET_USER_HOME}}|${HOME}|g" ${COMMSTATONE_CONF}

  if [ $? -ne 0 ]; then
    et-log "Error configuring CommStatOne"
    exit 1
  fi
}

start() {
  # Check/start JS8Call
  pgrep js8call > /dev/null 2>&1
  if [ $? -ne 0 ]; then
    et-log "Starting JS8Call..."
    /opt/emcomm-tools/bin/et-js8call start
    notify-send -u critical -i \
      /usr/share/icons/Yaru/48x48/status/dialog-information.png \
      "Starting JS8Call before CommStatOne..."
  fi

  # Wait for JS8Call to be listening
  if ! wait_for_js8call ; then
    et-log "Error connecting to JS8Call"
    exit 3
  fi

  if [[ ! -d ${COMMSTATONE_DIR} ]]; then
    notify_user "CommStatOne not found at ${COMMSTATONE_DIR}. Run the et-os-addons install."
    exit 1
  fi

  if [[ ! -e ${COMMSTATONE_DIR}/commstat.py ]]; then
    notify_user "CommStatOne main script not found. Reinstall may be needed."
    exit 1
  fi

  if ! update-config ; then
    et-log "Error updating CommStatOne config"
    exit 2
  fi

  cd "${COMMSTATONE_DIR}" && python3 commstat.py &
}

case $1 in
  start)
    start
    ;;
  update-config)
    update-config
    ;;
  *)
    echo "Invalid command."
    usage
    exit 1
  ;;
esac
